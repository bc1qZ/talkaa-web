.calendar-title {
  font-size: 52rpx;
  font-weight: 700;
  margin-top: 20rpx;
}

.week-row,
.date-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12rpx;
  text-align: center;
  margin-top: 22rpx;
}

.date-row {
  font-size: 42rpx;
  font-family: Georgia, serif;
  margin-bottom: 42rpx;
}

.active-date {
  background: #e9eee7;
  color: #3e7f5d;
  border-radius: 999rpx;
  padding: 12rpx 0;
  font-weight: 700;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 72rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.premium {
  padding: 18rpx 28rpx;
  background: #252321;
  color: #fff;
  border-radius: 999rpx;
  font-weight: 700;
}

.task-panel {
  padding: 16rpx 24rpx;
}

.task-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx dashed #ebe5db;
}

.task-row:last-child {
  border-bottom: 0;
}

.task-mark {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 4rpx solid #ddd4c6;
}

.task-mark-done {
  border-color: #3e7f5d;
  background: radial-gradient(circle, #3e7f5d 0 42%, transparent 44%);
}

.task-copy {
  flex: 1;
}

.task-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  background: #fdeceb;
  color: #bf5a49;
  border-radius: 16rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.task-title {
  font-size: 38rpx;
}

.task-subtitle {
  color: #8d867d;
  margin-top: 8rpx;
}

.task-arrow {
  color: #c1b8aa;
  font-size: 44rpx;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 28rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 180rpx;
  border-radius: 28rpx;
  border: 4rpx solid #26231f;
  background: #fffefb;
  box-shadow: 10rpx 12rpx 0 #66a27e;
  padding: 28rpx 18rpx;
  box-sizing: border-box;
}

.feature-icon {
  font-size: 42rpx;
}

.feature-cn {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.feature-en {
  margin-top: 6rpx;
  color: #8d867d;
}
